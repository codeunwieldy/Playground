<Window
    x:Class="Atlas.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Atlas File Intelligence">
    <Grid x:Name="RootGrid" Background="{StaticResource AtlasShellGradientBrush}">

        <Ellipse Width="520"
                 Height="520"
                 Margin="-190,-160,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="{StaticResource AtlasGlowBrush}"
                 IsHitTestVisible="False" />
        <Ellipse Width="460"
                 Height="460"
                 Margin="0,0,-180,-170"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="{StaticResource AtlasCopperGlowBrush}"
                 IsHitTestVisible="False" />

        <NavigationView x:Name="ShellView"
                        Margin="14"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        OpenPaneLength="286"
                        PaneDisplayMode="Left"
                        PaneTitle="Atlas"
                        SelectionChanged="OnSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="DashboardItem" Tag="dashboard" Content="Command Deck">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="PlansItem" Tag="plans" Content="Plan Review">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Preview" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="OptimizationItem" Tag="optimization" Content="Optimization">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Repair" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="UndoItem" Tag="undo" Content="Undo Timeline">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Undo" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="HistoryItem" Tag="history" Content="Atlas Memory">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsItem" Tag="settings" Content="Policy Studio">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Border Margin="12,8,12,18"
                        Padding="16"
                        Style="{StaticResource AtlasCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="GUARDRAILS" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Protected mode stays on" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                   Text="System paths stay blocked, sync roots stay excluded, and deletes route through quarantine before anything irreversible happens." />
                    </StackPanel>
                </Border>
            </NavigationView.PaneFooter>

            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Margin="18,18,18,0"
                        Padding="26"
                        Style="{StaticResource AtlasPanelStyle}">
                    <Grid RowSpacing="18" ColumnSpacing="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock x:Name="ShellEyebrowText"
                                       Style="{StaticResource AtlasEyebrowStyle}"
                                       Text="ATLAS COMMAND DECK" />
                            <TextBlock x:Name="ShellTitleText"
                                       Style="{StaticResource AtlasHeroTextStyle}"
                                       Text="Shape the machine without surrendering the safety rails." />
                            <TextBlock x:Name="ShellSubtitleText"
                                       MaxWidth="760"
                                       Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Ask Atlas to draft a plan, review duplicates, or inspect optimization pressure. Every destructive step is previewed first and paired with rollback metadata." />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Style="{StaticResource AtlasBadgeStyle}">
                                    <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="Preview before execute" />
                                </Border>
                                <Border Style="{StaticResource AtlasBadgeStyle}">
                                    <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="Quarantine-first deletion" />
                                </Border>
                                <Border Style="{StaticResource AtlasBadgeStyle}">
                                    <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="Undo journal armed" />
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Width="280"
                                    Spacing="12">
                            <Border Padding="16"
                                    Style="{StaticResource AtlasCardStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="StatusEyebrowText"
                                               Style="{StaticResource AtlasEyebrowStyle}"
                                               Text="SYSTEM POSTURE" />
                                    <TextBlock x:Name="StatusBadgeText"
                                               Style="{StaticResource AtlasSectionHeadingStyle}"
                                               Text="Planner locked to DSL" />
                                    <TextBlock x:Name="StatusDetailText"
                                               Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="The service remains the only component allowed to mutate files, create undo checkpoints, or apply optimization changes." />
                                </StackPanel>
                            </Border>

                            <CommandBar DefaultLabelPosition="Right"
                                        IsDynamicOverflowEnabled="False"
                                        OverflowButtonVisibility="Collapsed">
                                <AppBarButton Click="OnQuickNavigateClick" Tag="dashboard" Label="Scan">
                                    <AppBarButton.Icon>
                                        <SymbolIcon Symbol="Refresh" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Click="OnQuickNavigateClick" Tag="plans" Label="Plans">
                                    <AppBarButton.Icon>
                                        <SymbolIcon Symbol="Preview" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Click="OnQuickNavigateClick" Tag="undo" Label="Undo">
                                    <AppBarButton.Icon>
                                        <SymbolIcon Symbol="Undo" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                                <AppBarButton Click="OnQuickNavigateClick" Tag="history" Label="Memory">
                                    <AppBarButton.Icon>
                                        <SymbolIcon Symbol="Library" />
                                    </AppBarButton.Icon>
                                </AppBarButton>
                            </CommandBar>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Padding="18"
                                Style="{StaticResource AtlasCardStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="COMMAND INPUT" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <AutoSuggestBox x:Name="CommandInputBox"
                                                    PlaceholderText="Ask Atlas to organize Downloads, review duplicates, or prepare a safer cleanup plan"
                                                    TextChanged="OnCommandTextChanged"
                                                    QuerySubmitted="OnCommandSubmitted"
                                                    AutomationProperties.Name="Atlas command input" />

                                    <ToggleButton x:Name="VoiceToggleButton"
                                                  Grid.Column="1"
                                                  MinWidth="132"
                                                  Click="OnVoiceToggleClick"
                                                  Style="{StaticResource AtlasToggleButtonStyle}"
                                                  AutomationProperties.Name="Push to talk toggle"
                                                  Content="Push to talk" />

                                    <Button x:Name="PrimaryActionButton"
                                            Grid.Column="2"
                                            Click="OnPrimaryActionClick"
                                            Style="{StaticResource AtlasPrimaryButtonStyle}"
                                            AutomationProperties.Name="Primary action"
                                            Content="Draft plan" />
                                </Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Click="OnPromptRecipeClick"
                                            Style="{StaticResource AtlasChipButtonStyle}"
                                            Tag="Organize Downloads into calmer categories and route duplicate deletions through quarantine first."
                                            Content="Organize Downloads" />
                                    <Button Click="OnPromptRecipeClick"
                                            Style="{StaticResource AtlasChipButtonStyle}"
                                            Tag="Review screenshots, exports, and image clutter without touching sync-managed folders."
                                            Content="Triage Screenshots" />
                                    <Button Click="OnPromptRecipeClick"
                                            Style="{StaticResource AtlasChipButtonStyle}"
                                            Tag="Inspect temp buildup, startup clutter, and safe optimization opportunities."
                                            Content="Inspect Optimization" />
                                </StackPanel>
                                <ScrollViewer HorizontalScrollMode="Enabled"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollMode="Disabled"
                                              VerticalScrollBarVisibility="Disabled">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="460" />
                                            <ColumnDefinition Width="320" />
                                        </Grid.ColumnDefinitions>

                                        <Border Padding="16"
                                                Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="10">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="INTENT PREVIEW" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                                           Text="{Binding CommandInterpretationText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                           Text="{Binding CommandInterpretationDetailText}"
                                                           TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}"
                                                                   Text="{Binding CommandOriginLabel}" />
                                                    </Border>
                                                    <Border Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}"
                                                                   Text="{Binding CommandWorkspaceLabel}" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="14">
                                            <Border Padding="16"
                                                    Style="{StaticResource AtlasPanelStyle}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="REVIEW GATE" />
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                                               Text="{Binding CommandReviewLabel}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                               Text="{Binding CommandReviewDetailText}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Padding="16"
                                                    Style="{StaticResource AtlasPanelStyle}">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="NEXT STEP" />
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                                               Text="{Binding CommandNextStepLabel}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                               Text="{Binding CommandNextStepDetailText}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                                <TextBlock x:Name="ShellHintText"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="Draft a reviewed plan first. The shell will route you into the correct workspace before any filesystem change is even eligible." />
                                <TextBlock x:Name="VoiceStateText"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="Voice commands stay confirmation-first and use the same risk gates as typed input." />
                                <TextBlock x:Name="SessionStatusText"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="Atlas is standing by." />
                                <ProgressBar x:Name="BusyProgressBar"
                                             Height="6"
                                             IsIndeterminate="False"
                                             ShowError="False"
                                             ShowPaused="False" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Frame x:Name="ContentFrame"
                       Grid.Row="1"
                       Margin="18,0,18,18" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
