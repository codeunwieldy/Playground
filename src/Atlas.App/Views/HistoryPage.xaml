<Page
    x:Class="Atlas.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="28,22,28,32">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ATLAS MEMORY" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Session history now, persisted history next" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                               Text="This workspace keeps the latest command interpretations, review posture, activity outcomes, and recovery artifacts in one place. It is already useful in-session and is intentionally shaped to accept service-backed history summaries next."
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="OnPreviewUndoClick"
                                Style="{StaticResource AtlasSecondaryButtonStyle}"
                                Content="Preview undo"
                                IsEnabled="{Binding CanPreviewUndo}" />
                        <Button Click="OnRunScanClick"
                                Style="{StaticResource AtlasPrimaryButtonStyle}"
                                Content="Refresh scan" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding HistoryMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="20" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" Padding="18" Style="{StaticResource AtlasCardStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                    <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="460" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="LATEST COMMAND STORY" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding CommandInterpretationText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding CommandInterpretationDetailText}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Style="{StaticResource AtlasBadgeStyle}">
                                    <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding CommandOriginLabel}" />
                                </Border>
                                <Border Style="{StaticResource AtlasBadgeStyle}">
                                    <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding CommandWorkspaceLabel}" />
                                </Border>
                            </StackPanel>
                            <Border Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="REVIEW GATE" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding CommandReviewLabel}" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding CommandReviewDetailText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="NEXT MOVE" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding CommandNextStepLabel}" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding CommandNextStepDetailText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PERSISTENCE POSTURE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding ConnectionModeLabel}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ConnectionModeDetail}" TextWrapping="Wrap" />
                            <Border Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CURRENT STATUS" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding BusyStateLabel}" TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="The shell already retains a short in-session memory. Service-backed history summaries are the next layer and will flow into this workspace without changing the UX shape."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PLAN ASSURANCE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Latest planning posture" />
                            <ItemsControl ItemsSource="{Binding PlanSignals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY ASSURANCE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Latest undo posture" />
                            <ItemsControl ItemsSource="{Binding UndoSignals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="520" />
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                        <StackPanel Spacing="14">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECENT ACTIVITY" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What Atlas has done in this session" />
                            <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Width="110"
                                                           Style="{StaticResource AtlasEyebrowStyle}"
                                                           Text="{Binding Timestamp}" />
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" />
                                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="UNDO BATCHES" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Rollback artifacts" />
                            <ItemsControl ItemsSource="{Binding UndoBatches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="14" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Timestamp}" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="QUARANTINE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="File-level restore items" />
                            <ItemsControl ItemsSource="{Binding QuarantineEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="14" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Name}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding OriginalPath}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </StackPanel>
    </ScrollViewer>
</Page>
