<Page
    x:Class="Atlas.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="PageRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="DashboardStates">
                <VisualState x:Name="CompactDashboardState" />
                <VisualState x:Name="WideDashboardState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1460" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="PageContent.Padding" Value="28,22,28,34" />
                        <Setter Target="HeroAsideColumn.Width" Value="320" />
                        <Setter Target="HeroAsideRow.Height" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Row)" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Column)" Value="1" />
                        <Setter Target="HeroActionPanel.Orientation" Value="Horizontal" />
                        <Setter Target="HeroActionPanel.Spacing" Value="10" />
                        <Setter Target="SignalAsideColumn.Width" Value="360" />
                        <Setter Target="SignalAsideRow.Height" Value="0" />
                        <Setter Target="GuardrailCard.(Grid.Row)" Value="0" />
                        <Setter Target="GuardrailCard.(Grid.Column)" Value="1" />
                        <Setter Target="InsightAsideColumn.Width" Value="360" />
                        <Setter Target="InsightAsideRow.Height" Value="0" />
                        <Setter Target="VolumeCard.(Grid.Row)" Value="0" />
                        <Setter Target="VolumeCard.(Grid.Column)" Value="1" />
                        <Setter Target="TrustAsideColumn.Width" Value="360" />
                        <Setter Target="TrustAsideRow.Height" Value="0" />
                        <Setter Target="ActivityCard.(Grid.Row)" Value="0" />
                        <Setter Target="ActivityCard.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PageContent"
                        Padding="20,18,20,28"
                        Spacing="16">
                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HeroAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HeroAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="24"
                            Style="{StaticResource AtlasMissionDeckStyle}">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="MISSION PULSE" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasHeroTextStyle}"
                                           Text="{Binding ConnectionModeLabel}" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="{Binding InventorySummary}"
                                           TextWrapping="Wrap" />
                                <Rectangle Height="3"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                <StackPanel x:Name="HeroActionPanel"
                                            Orientation="Vertical"
                                            Spacing="8">
                                    <Button Click="OnRunScanClick"
                                            Content="Run scan"
                                            Style="{StaticResource AtlasPrimaryButtonStyle}" />
                                    <Button Click="OnRefreshHistoryClick"
                                            Content="Refresh memory"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}" />
                                    <Button Click="OnAnalyzeOptimizationClick"
                                            Content="Inspect optimization"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="18"
                                    Style="{StaticResource AtlasTelemetryPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="AI POSTURE" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                               Text="{Binding CurrentFocus}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="{Binding ConnectionModeDetail}"
                                               TextWrapping="Wrap" />
                                    <Border Style="{StaticResource AtlasBadgeStyle}">
                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}"
                                                   Text="Service-gated execution" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="HeroAsideCard"
                            Grid.Row="1"
                            Padding="20"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="OPERATING NOTE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                       Text="{Binding ScanPairSummaryText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="{Binding DriftHotspotSummaryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="SignalAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="SignalAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SIGNAL MATRIX" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Inventory, duplicate, and stored-scan pressure" />
                            <ItemsControl ItemsSource="{Binding DashboardMetrics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                           Text="{Binding Detail}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="GuardrailCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="GUARDRAILS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Scope, sync policy, and retained memory" />
                            <ItemsControl ItemsSource="{Binding InventorySignals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                           Text="{Binding Detail}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding MutableRootsSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ProtectedPathsSummaryText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="InsightAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="InsightAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="INTELLIGENCE LENS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Category shape and stored scan memory" />
                            <ItemsControl ItemsSource="{Binding TopCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding InventoryMemorySummaryText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="VolumeCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="VOLUME PRESSURE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Mounted volume posture and scan memory" />
                            <ItemsControl ItemsSource="{Binding Volumes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Title}" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PersistedVolumeSummaryText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="TrustAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="TrustAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="TRUST AND DRIFT" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Retained scan confidence and newest change evidence" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ScanTrustSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DriftFileSampleSummaryText}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding DriftFileSampleCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ActivityCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ACTIVITY FEED" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Recent shell activity" />
                            <ItemsControl ItemsSource="{Binding ActivityFeed}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Timestamp}" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
