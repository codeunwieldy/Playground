<Page
    x:Class="Atlas.App.Views.MemoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="28,22,28,32">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ATLAS MEMORY" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Session memory, retained scan evidence, and recovery posture" TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PersistedMemorySummaryText}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="OnRefreshMemoryClick" Style="{StaticResource AtlasSecondaryButtonStyle}" Content="Refresh memory" />
                        <Button Click="OnRunScanClick" Style="{StaticResource AtlasPrimaryButtonStyle}" Content="Refresh scan" />
                        <Button Click="OnPreviewUndoClick" Style="{StaticResource AtlasSecondaryButtonStyle}" Content="Preview undo" IsEnabled="{Binding CanPreviewUndo}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding HistoryMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="20" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="260" Padding="18" Style="{StaticResource AtlasCardStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                    <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AtlasPanelStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SCAN MEMORY" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Current and retained inventory posture" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding InventoryMemorySummaryText}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding InventoryMemoryCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasCardStyle}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AtlasPanelStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="DRIFT AND TRUST" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What changed, and whether Atlas trusts it" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DriftReviewSummaryText}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ScanTrustSummaryText}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding DriftReviewCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasCardStyle}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RETAINED DUPLICATES" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Stored duplicate review pressure and session cleanup impact" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PersistedDuplicateSummaryText}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding PersistedDuplicateMemory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12" Spacing="3">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="DRILL-IN AND EXPLAINABILITY" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Why one duplicate group and one file matter right now" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DuplicateDetailSummaryText}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding DuplicateDetailCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12" Spacing="3">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding FileExplainabilitySummaryText}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding FileExplainabilityCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,12" Spacing="3">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PLANS AND TRACES" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Persisted organization and prompt history" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PersistedPlanSummaryText}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PersistedTraceSummaryText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Undo and quarantine posture" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding UndoSummary}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding QuarantineSummaryText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
