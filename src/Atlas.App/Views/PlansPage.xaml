<Page
    x:Class="Atlas.App.Views.PlansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="28,22,28,32">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="REORGANIZATION PREVIEW" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding PlanSummary}" TextWrapping="Wrap" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding RiskSummary}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="OnPreviewExecutionClick" Style="{StaticResource AtlasSecondaryButtonStyle}" Content="Preview execution" IsEnabled="{Binding CanPreviewExecution}" />
                        <Button Click="OnExecutePlanClick" Style="{StaticResource AtlasPrimaryButtonStyle}" Content="Execute through service" IsEnabled="{Binding CanExecutePlan}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding PlanMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="20" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="240" Padding="18" Style="{StaticResource AtlasCardStyle}">
                                <StackPanel Spacing="6">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                    <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="22">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SCAN DRIFT CONTEXT" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What shifted between the latest stored scans before planning" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DriftReviewSummaryText}" TextWrapping="Wrap" />

                    <ScrollViewer HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DriftReviewCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="18" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Padding="18" Style="{StaticResource AtlasPanelStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="22">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SCAN PROVENANCE CONTEXT" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="How Atlas built the inventory underlying this plan" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ScanProvenanceSummaryText}" TextWrapping="Wrap" />

                    <ScrollViewer HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ScanProvenanceSignals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="18" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Padding="18" Style="{StaticResource AtlasPanelStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                            <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="22">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CHANGED PATH SAMPLE" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Bounded file evidence behind this plan's drift window" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DriftFileSampleSummaryText}" TextWrapping="Wrap" />

                    <ScrollViewer HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DriftFileSampleCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="18" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Padding="18" Style="{StaticResource AtlasPanelStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="22">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="DRIFT HOTSPOTS" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What kinds of files are shifting most before this plan" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DriftHotspotSummaryText}" TextWrapping="Wrap" />

                    <ScrollViewer HorizontalScrollMode="Enabled"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DriftHotspotCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="18" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Padding="18" Style="{StaticResource AtlasPanelStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding PlanSignals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="20" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="280" Padding="18" Style="{StaticResource AtlasPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                    <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="22">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="BLOCKED REASONS" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What could still stop this batch" />
                    <ItemsControl ItemsSource="{Binding PlanBlockedReasons}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="8" Height="8" Margin="0,7,0,0" Fill="{StaticResource AtlasCopperBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="{Binding}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="22">
                <StackPanel Spacing="10">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="STRUCTURE DIFF" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Before and after, at a glance" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanDiffNarrativeText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="14">
                            <Rectangle Height="4" RadiusX="2" RadiusY="2" Fill="{StaticResource AtlasLineBrush}" />
                            <StackPanel Spacing="6">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CURRENT LAYOUT" />
                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What Atlas sees now" />
                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="A read-only view of how files are currently spread across the mutable workspace." TextWrapping="Wrap" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding CurrentStructureGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                    <Border Grid.Column="1" Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding Value}" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AtlasTextBrush}" Opacity="0.84" Text="{Binding Sample}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="14">
                            <Rectangle Height="4" RadiusX="2" RadiusY="2" Fill="{StaticResource AtlasAccentBrush}" />
                            <StackPanel Spacing="6">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PROPOSED LAYOUT" />
                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Where the approved plan lands" />
                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Atlas turns free-form file spread into explicit anchors, placements, and quarantine-first review." TextWrapping="Wrap" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding ProposedStructureGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                    <Border Grid.Column="1" Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding Value}" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                <TextBlock FontSize="12" Foreground="{StaticResource AtlasTextBrush}" Opacity="0.84" Text="{Binding Sample}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="700" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PLANNED OPERATIONS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Incoming operations" />
                            <ItemsControl ItemsSource="{Binding PlanOperations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="16" Style="{StaticResource AtlasPanelStyle}">
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Kind}" />
                                                    <Border Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding Status}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PathLine}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ROLLBACK STORY" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding UndoSummary}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Atlas keeps the plan review surface tied to rollback metadata, even in preview mode." TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ConnectionModeDetail}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RATIONALE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Why Atlas chose this shape" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanRationaleText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="EXPECTED BENEFIT" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What improves if you approve it" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanBenefitText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource AtlasCardStyle}" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ROLLBACK STRATEGY" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="How Atlas gets back out" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanRollbackText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </StackPanel>
    </ScrollViewer>
</Page>
