<Page
    x:Class="Atlas.App.Views.PlansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="PlanStates">
                <VisualState x:Name="CompactPlanState" />
                <VisualState x:Name="WidePlanState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1500" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="PageContent.Padding" Value="28,22,28,34" />
                        <Setter Target="ContextColumn.Width" Value="360" />
                        <Setter Target="ContextRow.Height" Value="0" />
                        <Setter Target="ContextCard.(Grid.Row)" Value="0" />
                        <Setter Target="ContextCard.(Grid.Column)" Value="1" />
                        <Setter Target="OperationsColumn.Width" Value="360" />
                        <Setter Target="OperationsRow.Height" Value="0" />
                        <Setter Target="ReviewCard.(Grid.Row)" Value="0" />
                        <Setter Target="ReviewCard.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PageContent"
                        Padding="20,18,20,28"
                        Spacing="16">
                <Border Padding="24"
                        Style="{StaticResource AtlasMissionDeckStyle}">
                    <Grid ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PLAN REVIEW" />
                            <TextBlock Style="{StaticResource AtlasHeroTextStyle}" Text="{Binding PlanSummary}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding RiskSummary}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Click="OnPromoteCleanupPlanClick"
                                        Style="{StaticResource AtlasSecondaryButtonStyle}"
                                        Content="Save retained cleanup plan"
                                        IsEnabled="{Binding CanPromoteRetainedCleanupPlan}" />
                                <Button Click="OnPreviewExecutionClick"
                                        Style="{StaticResource AtlasSecondaryButtonStyle}"
                                        Content="Preview execution"
                                        IsEnabled="{Binding CanPreviewExecution}" />
                                <Button Click="OnExecutePlanClick"
                                        Style="{StaticResource AtlasPrimaryButtonStyle}"
                                        Content="Execute through service"
                                        IsEnabled="{Binding CanExecutePlan}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="18"
                                Style="{StaticResource AtlasTelemetryPanelStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="REVIEW POSTURE" />
                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                           Text="{Binding PlanSignalSummaryText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="{Binding ScanTrustSummaryText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer HorizontalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PlanMetrics}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                        <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="ContextColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="ContextRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="STRUCTURE DIFF" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding PlanDiffNarrativeText}" TextWrapping="Wrap" />
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CURRENT LAYOUT" />
                                    <ItemsControl ItemsSource="{Binding CurrentStructureGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Value}" />
                                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="10">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PROPOSED LAYOUT" />
                                    <ItemsControl ItemsSource="{Binding ProposedStructureGroups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Value}" />
                                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ContextCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PLAN CONTEXT" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Trust, provenance, and drift behind the plan" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ScanTrustSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding ScanProvenanceSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DriftReviewSummaryText}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding ScanTrustSignals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="OperationsColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="OperationsRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PLANNED OPERATIONS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Validated operations ready for review" />
                            <ItemsControl ItemsSource="{Binding PlanOperations}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Kind}" />
                                                    <Border Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding Status}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PathLine}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ReviewCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="REVIEW EVIDENCE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Duplicates, explainability, blocked reasons, and retained cleanup plan posture" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DuplicateDetailSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PersistedPlanSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding FileExplainabilitySummaryText}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding DuplicateDetailCards}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding PlanBlockedReasons}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Padding="14" Style="{StaticResource AtlasMicroPanelStyle}">
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding}" TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Padding="22"
                        Style="{StaticResource AtlasStagePanelStyle}">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RATIONALE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Why Atlas chose this shape" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanRationaleText}" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="EXPECTED BENEFIT" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="What improves if you approve it" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanBenefitText}" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ROLLBACK STRATEGY" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="How Atlas gets back out" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding PlanRollbackText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
