<Page
    x:Class="Atlas.App.Views.UndoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="UndoStates">
                <VisualState x:Name="CompactUndoState" />
                <VisualState x:Name="WideUndoState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1460" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="PageContent.Padding" Value="28,22,28,34" />
                        <Setter Target="HeroAsideColumn.Width" Value="320" />
                        <Setter Target="HeroAsideRow.Height" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Row)" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Column)" Value="1" />
                        <Setter Target="HeroActionPanel.Orientation" Value="Horizontal" />
                        <Setter Target="HeroActionPanel.Spacing" Value="10" />
                        <Setter Target="HistoryAsideColumn.Width" Value="360" />
                        <Setter Target="HistoryAsideRow.Height" Value="0" />
                        <Setter Target="SignalsCard.(Grid.Row)" Value="0" />
                        <Setter Target="SignalsCard.(Grid.Column)" Value="1" />
                        <Setter Target="RecoveryAsideColumn.Width" Value="360" />
                        <Setter Target="RecoveryAsideRow.Height" Value="0" />
                        <Setter Target="NotesCard.(Grid.Row)" Value="0" />
                        <Setter Target="NotesCard.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PageContent"
                        Padding="20,18,20,28"
                        Spacing="16">
                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HeroAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HeroAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="24"
                            Style="{StaticResource AtlasMissionDeckStyle}">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY MISSION" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasHeroTextStyle}"
                                           Text="{Binding UndoSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="Atlas keeps destructive work reversible through inverse operations, quarantine restores, and later checkpoint depth. Recovery should feel like an intentional control room, not a panic button."
                                           TextWrapping="Wrap" />
                                <Rectangle Height="3"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                <StackPanel x:Name="HeroActionPanel"
                                            Orientation="Vertical"
                                            Spacing="8">
                                    <Button Click="OnPreviewUndoClick"
                                            Content="Preview undo"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}"
                                            IsEnabled="{Binding CanPreviewUndo}" />
                                    <Button Click="OnExecuteUndoClick"
                                            Content="Execute through service"
                                            Style="{StaticResource AtlasPrimaryButtonStyle}"
                                            IsEnabled="{Binding CanExecuteUndo}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="18"
                                    Style="{StaticResource AtlasTelemetryPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY NOTE" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                               Text="{Binding UndoSignalSummaryText}"
                                               TextWrapping="Wrap" />
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="3*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasStrongBorderBrush}" Opacity="0.55" />
                                        <Rectangle Grid.Column="1" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                        <Rectangle Grid.Column="2" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasSignalBrush}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="HeroAsideCard"
                            Grid.Row="1"
                            Padding="20"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY STANCE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                       Text="{Binding QuarantineSummaryText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Quarantine-first cleanup means Atlas can often restore single items without needing a full batch reversal."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer HorizontalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding UndoMetrics}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240"
                                        Padding="16"
                                        Style="{StaticResource AtlasMicroPanelStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                        <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                   Text="{Binding Detail}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HistoryAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HistoryAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ROLLBACK BATCHES" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Recent recovery-ready batches" />
                            <ItemsControl ItemsSource="{Binding UndoBatches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Timestamp}" />
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Title}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SignalsCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY SIGNALS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Checkpoint strength and restore coverage" />
                            <ItemsControl ItemsSource="{Binding UndoSignals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                                <TextBlock Style="{StaticResource AtlasSignalValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="RecoveryAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="RecoveryAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="QUARANTINE RECOVERY" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Directly restorable items" />
                            <ItemsControl ItemsSource="{Binding QuarantineEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Name}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding OriginalPath}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="NotesCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RECOVERY MESH" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="How the current rollback story is composed" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding RecoveryAssetMixText}" TextWrapping="Wrap" />
                            <Border Padding="16" Style="{StaticResource AtlasTelemetryPanelStyle}">
                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Inverse operations" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource AtlasInsightValueStyle}"
                                                   Text="{Binding RecoveryInverseAssetCount}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource AtlasInsightBarStyle}"
                                                 Value="{Binding RecoveryInverseAssetPercent}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Direct step-by-step reversals Atlas can replay for the current checkpoint."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Quarantine restores" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource AtlasInsightValueStyle}"
                                                   Text="{Binding RecoveryQuarantineAssetCount}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource AtlasInsightBarStyle}"
                                                 Value="{Binding RecoveryQuarantineAssetPercent}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Single-item restores that can come back without rewinding the whole batch."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Optimization rollback states" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource AtlasInsightValueStyle}"
                                                   Text="{Binding RecoveryOptimizationRollbackCount}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource AtlasInsightBarStyle}"
                                                 Value="{Binding RecoveryOptimizationRollbackPercent}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Tracked fix-specific rollback data for optimization work that touched the machine."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CHECKPOINT DETAIL" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding CheckpointDetailSummaryText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CHECKPOINT NOTES" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding UndoNotesText}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Atlas should be able to explain whether this recovery path is inverse-op driven, quarantine-restorable, or waiting on deeper checkpoint coverage."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
