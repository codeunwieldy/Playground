<Page
    x:Class="Atlas.App.Views.OptimizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="OptimizationStates">
                <VisualState x:Name="CompactOptimizationState" />
                <VisualState x:Name="WideOptimizationState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1460" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="PageContent.Padding" Value="28,22,28,34" />
                        <Setter Target="HeroAsideColumn.Width" Value="320" />
                        <Setter Target="HeroAsideRow.Height" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Row)" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Column)" Value="1" />
                        <Setter Target="HeroActionPanel.Orientation" Value="Horizontal" />
                        <Setter Target="HeroActionPanel.Spacing" Value="10" />
                        <Setter Target="FindingsAsideColumn.Width" Value="360" />
                        <Setter Target="FindingsAsideRow.Height" Value="0" />
                        <Setter Target="FixPostureCard.(Grid.Row)" Value="0" />
                        <Setter Target="FixPostureCard.(Grid.Column)" Value="1" />
                        <Setter Target="EvidenceAsideColumn.Width" Value="360" />
                        <Setter Target="EvidenceAsideRow.Height" Value="0" />
                        <Setter Target="RulesCard.(Grid.Row)" Value="0" />
                        <Setter Target="RulesCard.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PageContent"
                        Padding="20,18,20,28"
                        Spacing="16">
                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HeroAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HeroAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="24"
                            Style="{StaticResource AtlasMissionDeckStyle}">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PERFORMANCE GRID" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasHeroTextStyle}"
                                           Text="{Binding OptimizationSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="Atlas only auto-fixes curated low-risk pressure like temp cleanup, cache buildup, duplicate archives, and user startup clutter. Everything else stays review-first and rollback-aware."
                                           TextWrapping="Wrap" />
                                <Rectangle Height="3"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                <StackPanel x:Name="HeroActionPanel"
                                            Orientation="Vertical"
                                            Spacing="8">
                                    <Button Click="OnAnalyzeOptimizationClick"
                                            Content="Analyze optimization"
                                            Style="{StaticResource AtlasPrimaryButtonStyle}" />
                                    <Button Click="OnPreviewOptimizationFixClick"
                                            Content="Preview lead fix"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}"
                                            IsEnabled="{Binding CanPreviewOptimizationFix}" />
                                    <Button Click="OnApplyOptimizationFixClick"
                                            Content="Apply lead fix"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}"
                                            IsEnabled="{Binding CanApplyOptimizationFix}" />
                                    <Button Click="OnRevertOptimizationFixClick"
                                            Content="Revert last fix"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}"
                                            IsEnabled="{Binding CanRevertOptimizationFix}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="18"
                                    Style="{StaticResource AtlasTelemetryPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="FIX POSTURE" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                               Text="Safe fixes stay narrow"
                                               TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Atlas uses a small trusted optimizer lane instead of broad system tweaking."
                                               TextWrapping="Wrap" />
                                    <Grid ColumnSpacing="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasSignalBrush}" />
                                        <Rectangle Grid.Column="1" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                        <Rectangle Grid.Column="2" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasStrongBorderBrush}" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="HeroAsideCard"
                            Grid.Row="1"
                            Padding="20"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="OPERATING NOTE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                       Text="Lead safe-fix control"
                                       TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="{Binding OptimizationFixSummaryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <ScrollViewer HorizontalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding OptimizationMetrics}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="16" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240"
                                        Padding="16"
                                        Style="{StaticResource AtlasMicroPanelStyle}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="{Binding Eyebrow}" />
                                        <TextBlock Style="{StaticResource AtlasMetricValueStyle}" Text="{Binding Value}" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                                   Text="{Binding Detail}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="FindingsAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="FindingsAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="FINDING BOARD" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Fix candidates, evidence, and rollback notes" />
                            <ItemsControl ItemsSource="{Binding OptimizationFindings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <StackPanel Spacing="8">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding Kind}" />
                                                    <Border Style="{StaticResource AtlasBadgeStyle}">
                                                        <TextBlock Foreground="{StaticResource AtlasBadgeTextBrush}" Text="{Binding Status}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Target}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding Evidence}" TextWrapping="Wrap" />
                                                <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding RollbackPlan}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="FixPostureCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ACTION MIX" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="How Atlas is splitting the current optimization load" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="{Binding OptimizationActionMixText}"
                                       TextWrapping="Wrap" />
                            <Border Padding="16" Style="{StaticResource AtlasTelemetryPanelStyle}">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Auto-fix lane" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource AtlasInsightValueStyle}"
                                                   Text="{Binding OptimizationAutoFixReadyCount}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource AtlasInsightBarStyle}"
                                                 Value="{Binding OptimizationAutoFixPercent}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Curated cleanup Atlas can keep in the trusted fix lane once the service is live."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Approval gate" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource AtlasInsightValueStyle}"
                                                   Text="{Binding OptimizationApprovalGateCount}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource AtlasInsightBarStyle}"
                                                 Value="{Binding OptimizationApprovalPercent}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Signals that Atlas can explain clearly but still wants a human to review before action."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Recommendation-only lane" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource AtlasInsightValueStyle}"
                                                   Text="{Binding OptimizationRecommendationOnlyCount}" />
                                    </Grid>
                                    <ProgressBar Style="{StaticResource AtlasInsightBarStyle}"
                                                 Value="{Binding OptimizationRecommendationPercent}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="Broader opportunities that stay informational until the optimizer grows deeper rollback coverage."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="EvidenceAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="EvidenceAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SYSTEM BEHAVIOR" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Optimization avoids generic tuner behavior" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Atlas does not touch Microsoft services, drivers, registry tweak packs, or mystery cleanup heuristics. The optimizer is intentionally smaller, clearer, and easier to undo."
                                       TextWrapping="Wrap" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="TEMP FLOW" />
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Disk pressure relief" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Safe file cleanup stays volume-local and reversible where possible." TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="CACHE FLOW" />
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Bounded cache trimming" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Atlas prefers oversized cache roots and known cleanup targets over blind sweeping." TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="STARTUP FLOW" />
                                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="User-level startup only" />
                                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Startup cleanup stays inside user-owned entries instead of reaching into system service territory." TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="RulesCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ROLLBACK RULES" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Every fix needs an exit path" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Optimization fixes should either be directly reversible, safely idempotent, or recommendation-only. Atlas avoids pretending cleanup is reversible when it is not."
                                       TextWrapping="Wrap" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasSignalBrush}" />
                                <Rectangle Grid.Column="1" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasSignalBrush}" Opacity="0.8" />
                                <Rectangle Grid.Column="2" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasTelemetryLineBrush}" Opacity="0.72" />
                                <Rectangle Grid.Column="3" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasStrongBorderBrush}" Opacity="0.5" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
