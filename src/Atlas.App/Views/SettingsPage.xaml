<Page
    x:Class="Atlas.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="SettingsStates">
                <VisualState x:Name="CompactSettingsState" />
                <VisualState x:Name="WideSettingsState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1460" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="PageContent.Padding" Value="28,22,28,34" />
                        <Setter Target="HeroAsideColumn.Width" Value="320" />
                        <Setter Target="HeroAsideRow.Height" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Row)" Value="0" />
                        <Setter Target="HeroAsideCard.(Grid.Column)" Value="1" />
                        <Setter Target="HeroActionPanel.Orientation" Value="Horizontal" />
                        <Setter Target="HeroActionPanel.Spacing" Value="10" />
                        <Setter Target="PolicyAsideColumn.Width" Value="360" />
                        <Setter Target="PolicyAsideRow.Height" Value="0" />
                        <Setter Target="RetentionCard.(Grid.Row)" Value="0" />
                        <Setter Target="RetentionCard.(Grid.Column)" Value="1" />
                        <Setter Target="PathAsideColumn.Width" Value="360" />
                        <Setter Target="PathAsideRow.Height" Value="0" />
                        <Setter Target="ProtectedCard.(Grid.Row)" Value="0" />
                        <Setter Target="ProtectedCard.(Grid.Column)" Value="1" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PageContent"
                        Padding="20,18,20,28"
                        Spacing="16">
                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="HeroAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="HeroAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="24"
                            Style="{StaticResource AtlasMissionDeckStyle}">
                        <Grid ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="POLICY STUDIO" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasHeroTextStyle}"
                                           Text="Guardrails stay explicit, reviewable, and hard to weaken by accident."
                                           TextWrapping="Wrap" />
                                <TextBlock MaxWidth="760"
                                           Style="{StaticResource AtlasBodyTextStyle}"
                                           Text="Tune sync-folder policy, content upload posture, duplicate confidence, and retention without stepping outside the service-owned safety boundary."
                                           TextWrapping="Wrap" />
                                <Rectangle Height="3"
                                           RadiusX="1.5"
                                           RadiusY="1.5"
                                           Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                <StackPanel x:Name="HeroActionPanel"
                                            Orientation="Vertical"
                                            Spacing="8">
                                    <Button Click="OnSaveClick"
                                            Content="Save policy"
                                            Style="{StaticResource AtlasPrimaryButtonStyle}" />
                                    <Button Click="OnResetClick"
                                            Content="Reset defaults"
                                            Style="{StaticResource AtlasSecondaryButtonStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="18"
                                    Style="{StaticResource AtlasTelemetryPanelStyle}">
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="POLICY POSTURE" />
                                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                               Text="{Binding MutableRootsSummaryText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="{Binding ProtectedPathsSummaryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="HeroAsideCard"
                            Grid.Row="1"
                            Padding="20"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SAFETY LOCKS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}"
                                       Text="Atlas is configurable, not permissive"
                                       TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Policy settings should refine safe behavior and visibility, not punch holes through protected roots, service validation, or quarantine-first cleanup."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="PolicyAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="PolicyAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="LIVE POLICY SWITCHES" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Service-facing defaults Atlas will respect" />
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="SYNC FOLDERS" />
                                    <ToggleSwitch Header="Exclude sync folders by default"
                                                  IsOn="{Binding ExcludeSyncFoldersByDefault, Mode=TwoWay}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="This keeps cloud-managed trees out of the normal mutation path unless you deliberately opt in."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="AI PRIVACY" />
                                    <ToggleSwitch Header="Allow sensitive content upload"
                                                  IsOn="{Binding UploadSensitiveContent, Mode=TwoWay}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="When this stays off, Atlas keeps high-sensitivity file identities redacted before sending planning payloads to the model."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Style="{StaticResource AtlasMicroPanelStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="AUTO-FIX LANE" />
                                    <ToggleSwitch Header="Auto-fix low-risk optimizations"
                                                  IsOn="{Binding AutoFixLowRiskOptimizations, Mode=TwoWay}" />
                                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                               Text="This only affects the small safe optimization set and does not widen Atlas into generic system tweaking."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="RetentionCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RETENTION AND CONFIDENCE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Cleanup stays strict and reversible" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding QuarantineRetentionLabel}" TextWrapping="Wrap" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding DuplicateConfidenceThresholdLabel}" TextWrapping="Wrap" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasStrongBorderBrush}" Opacity="0.48" />
                                <Rectangle Grid.Column="1" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasTelemetryLineBrush}" />
                                <Rectangle Grid.Column="2" Height="7" RadiusX="3.5" RadiusY="3.5" Fill="{StaticResource AtlasSignalBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RETENTION WINDOW" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding QuarantineRetentionLabel}" />
                            <ComboBox x:Name="RetentionComboBox"
                                      SelectionChanged="OnRetentionSelectionChanged">
                                <ComboBoxItem Content="7 days" Tag="7" />
                                <ComboBoxItem Content="30 days" Tag="30" />
                                <ComboBoxItem Content="60 days" Tag="60" />
                                <ComboBoxItem Content="90 days" Tag="90" />
                            </ComboBox>
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Longer retention grows restore confidence but also expands how long Atlas keeps quarantine payloads on disk."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="DUPLICATE CONFIDENCE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding DuplicateConfidenceThresholdLabel}" />
                            <Slider Minimum="0.95"
                                    Maximum="1.0"
                                    StepFrequency="0.005"
                                    Value="{Binding DuplicateConfidenceThreshold, Mode=TwoWay}" />
                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}"
                                       Text="Atlas only auto-stages duplicate cleanup when confidence stays extremely high and the group does not look sensitive, protected, or sync-managed."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="16"
                      RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="PathAsideColumn" Width="0" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition x:Name="PathAsideRow" Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="APPROVED MUTATION SCOPE" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Mutable roots Atlas may reorganize" />
                            <ItemsControl ItemsSource="{Binding MutableRoots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding}" TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ProtectedCard"
                            Grid.Row="1"
                            Padding="22"
                            Style="{StaticResource AtlasStagePanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="ALWAYS-BLOCKED PATHS" />
                            <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Protected roots Atlas will not mutate" />
                            <ItemsControl ItemsSource="{Binding ProtectedPaths}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="16"
                                                Style="{StaticResource AtlasMicroPanelStyle}">
                                            <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding}" TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
