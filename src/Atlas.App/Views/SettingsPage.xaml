<Page
    x:Class="Atlas.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="28,22,28,32">
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="POLICY CONTROLS" />
                    <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Guardrails stay explicit" />
                    <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Tune protected paths, duplicate thresholds, cloud-folder behavior, and content upload permissions without weakening the hard safety boundary." TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Click="OnSaveClick" Style="{StaticResource AtlasPrimaryButtonStyle}" Content="Save policy" />
                        <Button Click="OnResetClick" Style="{StaticResource AtlasSecondaryButtonStyle}" Content="Reset defaults" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                <StackPanel Spacing="16">
                    <ToggleSwitch Header="Exclude sync folders by default" IsOn="{Binding ExcludeSyncFoldersByDefault, Mode=TwoWay}" />
                    <ToggleSwitch Header="Allow sensitive content upload" IsOn="{Binding UploadSensitiveContent, Mode=TwoWay}" />
                    <ToggleSwitch Header="Auto-fix low-risk optimizations" IsOn="{Binding AutoFixLowRiskOptimizations, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="RETENTION" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding QuarantineRetentionLabel}" />
                        <ComboBox x:Name="RetentionComboBox" SelectionChanged="OnRetentionSelectionChanged">
                            <ComboBoxItem Content="7 days" Tag="7" />
                            <ComboBoxItem Content="30 days" Tag="30" />
                            <ComboBoxItem Content="60 days" Tag="60" />
                            <ComboBoxItem Content="90 days" Tag="90" />
                        </ComboBox>
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Longer retention increases restore confidence, but Atlas still aims to stay compact on disk." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="DUPLICATE THRESHOLD" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="{Binding DuplicateConfidenceThresholdLabel}" />
                        <Slider Minimum="0.95" Maximum="1.0" StepFrequency="0.005" Value="{Binding DuplicateConfidenceThreshold, Mode=TwoWay}" />
                        <TextBlock Style="{StaticResource AtlasBodyTextStyle}" Text="Atlas only auto-stages duplicates when confidence stays extremely high and the sensitivity profile stays low." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="MUTABLE ROOTS" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Approved organization targets" />
                        <ItemsControl ItemsSource="{Binding MutableRoots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,8" Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AtlasCardStyle}" Padding="24">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource AtlasEyebrowStyle}" Text="PROTECTED PATHS" />
                        <TextBlock Style="{StaticResource AtlasSectionHeadingStyle}" Text="Always blocked by policy" />
                        <ItemsControl ItemsSource="{Binding ProtectedPaths}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,0,0,8" Style="{StaticResource AtlasBodyTextStyle}" Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
