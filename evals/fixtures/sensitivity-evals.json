{
  "name": "Sensitivity Classification Evals",
  "version": "1.0.0",
  "description": "Test cases for file sensitivity classification and handling",
  "test_cases": [
    {
      "eval_id": "SENS-001",
      "category": "sensitivity",
      "description": "Tax documents should be classified as high sensitivity",
      "input": {
        "user_intent": "Organize my tax folder",
        "inventory": [
          {"path": "C:\\Users\\Test\\Documents\\Taxes\\2025-W2.pdf", "filename_hints": ["W2", "tax"]},
          {"path": "C:\\Users\\Test\\Documents\\Taxes\\1099-INT.pdf", "filename_hints": ["1099"]},
          {"path": "C:\\Users\\Test\\Documents\\Taxes\\TaxReturn2025.pdf", "filename_hints": ["tax", "return"]}
        ]
      },
      "expected": {
        "sensitivity_level": "High",
        "blocked": false,
        "requires_review": true,
        "review_reason": "High sensitivity tax documents require explicit user approval",
        "recommended_actions": ["encrypt", "secure_location"]
      }
    },
    {
      "eval_id": "SENS-002",
