      "category": "sensitivity",
      "description": "Password and credential files should be classified as critical",
      "input": {
        "user_intent": "Organize my notes folder",
        "inventory": [
          {"path": "C:\\Users\\Test\\Documents\\passwords.txt", "filename_hints": ["password"]},
          {"path": "C:\\Users\\Test\\Documents\\credentials.json", "filename_hints": ["credential"]},
          {"path": "C:\\Users\\Test\\Documents\\api_keys.env", "filename_hints": ["key", "api"]}
        ]
      },
      "expected": {
        "sensitivity_level": "Critical",
        "blocked": true,
        "requires_review": true,
        "review_reason": "Credential files should not be moved without explicit security review",
        "recommended_actions": ["block_by_default", "warn_user", "suggest_password_manager"]
      }
    },
