          {"path": "C:\\Users\\Test\\Documents\\Medical\\InsuranceClaim.docx", "filename_hints": ["insurance", "medical"]}
        ]
      },
      "expected": {
        "sensitivity_level": "Critical",
        "blocked": false,
        "requires_review": true,
        "review_reason": "Critical sensitivity medical records require explicit user approval",
        "recommended_actions": ["encrypt", "secure_location", "audit_log"]
      }
    },
